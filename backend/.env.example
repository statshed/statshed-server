# StatShed Backend Configuration
# Copy this file to .env and customize for your environment

# Host port the backend will be exposed on (container always listens on 7828 internally)
HOST_PORT=7828

# Database URL (SQLite is default, can also use PostgreSQL)
DATABASE_URL=sqlite:////data/statshed.db

# CORS origins - frontend URL(s) allowed to access the API
# Use comma-separated values for multiple origins
CORS_ORIGINS=http://localhost:7827

# Secret key for session/token signing
# WARNING: Generate a strong random string for production (e.g., openssl rand -hex 32)
# An empty key is insecure and should only be used for local development
SECRET_KEY=

# Debug mode (set to false in production)
DEBUG=false

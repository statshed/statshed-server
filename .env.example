# StatShed server configuration.
# Copy to .env and customize:   cp .env.example .env

# --- Port exposed on the host ---
# Host port for the whole app: dashboard, REST API, the SSE stream, and CLI status POSTs.
# Open http://localhost:${STATSHED_PORT} in a browser; CLI clients POST to the same port.
STATSHED_PORT=7827

# --- Server ---
# Database. The Go server is SQLite-only; the default DB is persisted in the "statshed-data"
# Docker volume. It is fresh-DB-only: it creates + migrates an EMPTY database on first start
# and refuses to adopt a pre-existing or incompatible one.
DATABASE_URL=sqlite:////data/statshed.db

# Debug logging. true raises the slog level to DEBUG (verbose request logs). Keep false in
# production.
DEBUG=false

# Origins allowed to call the API from a browser (same-origin in the normal bundled
# deployment — CORS only matters if a browser hits the app from a different origin).
# Comma-separated.
# CORS_ORIGINS=https://your-other-origin.example.com

# Accept log uploads on POST /api/status (enabled by default). Set false to reject logs.
# LOG_UPLOAD_ENABLED=true

# Maximum log lines stored per job; the rest are truncated. Default 1000.
# MAX_LOG_LINES=1000

# Server-side cap on the GET /api/jobs `limit` page size; a larger requested limit is
# clamped to this. Default 500.
# MAX_JOBS_PAGE_SIZE=500

# Serve the SPA from this directory instead of the embedded build (dev / override). When the
# path does not exist the binary serves its embedded SPA; STATIC_DISABLED=1 turns SPA serving
# off entirely.
# STATIC_DIR=./static

# AIDEV-NOTE: SECRET_KEY is unused by the Go server (it keeps no session secret). It is
# accepted-and-ignored only so a .env carried over from the legacy Python image still works.
# SECRET_KEY=

# --- Releases (docker-compose.release.yml only) ---
# Image tag to pull from ghcr.io/statshed. Use a released version like v0.1.0,
# or "latest" for the most recent published build.
STATSHED_VERSION=latest

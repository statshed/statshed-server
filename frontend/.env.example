# StatShed Frontend Configuration
# Copy this file to .env and customize for your environment

# Port the frontend will be exposed on
FRONTEND_PORT=7827

# Backend URL for the browser's WebSocket - used at BUILD time (baked into the JS bundle).
# Leave this EMPTY for the normal deployment: the browser then connects to the same origin and
# nginx proxies /socket.io (and /api) to BACKEND_URL below. This is what you want.
#
# WARNING: VITE_* variables are embedded in the client bundle and shipped to every browser.
# If you set this, that exact URL is hardcoded into the bundle for ALL users — never set it to
# http://localhost:... (that points at each visitor's own machine and breaks realtime). Only set
# it when serving the bundle WITHOUT this nginx proxy, and then use a public HTTPS URL.
VITE_BACKEND_URL=

# Backend URL - used at runtime for nginx proxy
# IMPORTANT: Keep this aligned with VITE_BACKEND_URL to avoid CORS/mixed-content issues
BACKEND_URL=http://localhost:7828

# StatShed Frontend Build-Time Configuration
# Copy this file to .env and customize if needed.
#
# In the normal unified deployment (the single statshed-server Docker image), you do NOT
# need to set anything here. Flask serves /api and /socket.io on the same origin as the
# SPA, so the browser talks same-origin and no backend URL is required.

# Backend URL — BUILD-TIME variable baked into the JS bundle at `npm run build`.
#
# Leave EMPTY for the unified image: the browser will use the same origin as the page,
# and Flask handles /api and /socket.io directly.
#
# Only set this (to a public HTTPS URL, NEVER localhost) when you are building the SPA
# to talk to a different-origin backend (e.g. a separately hosted API server):
#   VITE_BACKEND_URL=https://api.example.com
#
# WARNING: VITE_* variables are embedded in the client bundle and visible to every
# browser. Never put secrets here, and never use http://localhost — that points at each
# visitor's own machine and breaks real-time updates for all other users.
VITE_BACKEND_URL=
